{
  "uid": "croptopus-overview",
  "title": "Croptopus Overview",
  "tags": ["croptopus"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Temperature per device",
      "datasource": { "type": "postgres", "uid": "timescale-main" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "celsius" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescale-main" },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT time AS \"time\", device_id AS metric, value FROM croptopus.measurements WHERE sensor_type = 'temperature' AND $__timeFilter(time) ORDER BY time"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Humidity per device",
      "datasource": { "type": "postgres", "uid": "timescale-main" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "humidity" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescale-main" },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT time AS \"time\", device_id AS metric, value FROM croptopus.measurements WHERE sensor_type = 'humidity' AND $__timeFilter(time) ORDER BY time"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Soil moisture per device",
      "datasource": { "type": "postgres", "uid": "timescale-main" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescale-main" },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT time AS \"time\", device_id AS metric, value FROM croptopus.measurements WHERE sensor_type = 'soil_moisture' AND $__timeFilter(time) ORDER BY time"
        }
      ]
    },
    {
      "id": 4,
      "type": "table",
      "title": "Device health (last seen / link quality)",
      "datasource": { "type": "postgres", "uid": "timescale-main" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescale-main" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT device_id, last_seen, last_rssi, last_snr FROM croptopus.devices ORDER BY last_seen DESC"
        }
      ]
    }
  ]
}
