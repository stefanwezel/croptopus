# Croptopus server stack — environment template.
# Copy to .env and edit. .env is gitignored; never commit real secrets.
# On Coolify, set these in the app's Environment Variables UI (they override .env).

# ---- TimescaleDB (Postgres) ----
# These three create the database/role on FIRST container start (empty volume).
POSTGRES_DB=croptopus
POSTGRES_USER=croptopus
POSTGRES_PASSWORD=change-me

# ---- Ingester DB connection ----
# Points at the timescaledb service over the compose network (service-name DNS).
# Host MUST be "timescaledb" (the service name), not localhost.
# Keep user/password/db in sync with the POSTGRES_* values above.
DATABASE_URL=postgresql://croptopus:change-me@timescaledb:5432/croptopus

# ---- Ingester auth ----
# Shared bearer token the BBB forwarder must send as: Authorization: Bearer <token>
INGEST_TOKEN=change-me

# ---- Grafana admin ----
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change-me
