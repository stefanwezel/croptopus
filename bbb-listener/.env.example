# Required for forwarding. Without these, listener runs in degraded mode
# (decode + log only, no server forwarding).
INGEST_URL=https://ingester.ouroborus.tech/ingest
INGEST_TOKEN=replace-with-the-same-value-from-coolify

# Optional tuning
INGEST_TIMEOUT_SECONDS=10
INGEST_BATCH_SIZE=50
INGEST_MAX_ATTEMPTS=10
QUEUE_DB_PATH=/home/debian/lora_listener_queue.sqlite3
